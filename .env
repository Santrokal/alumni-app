spring.application.name=alumni-app
spring.datasource.url=jdbc:mysql://localhost:3307/DB_NAME
spring.datasource.username=DB_USERNAME
spring.datasource.password=DB_PASSWPRD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
server.port=8080

spring.servlet.multipart.enabled=true	
spring.servlet.multipart.max-file-size=1000000MB
spring.servlet.multipart.max-request-size=1000000MB

spring.mvc.view.suffix=.jsp
spring.mvc.view.prefix=/WEB-INF/

payu.merchant_key=MERCHANT_KEY
payu.salt=AUTO_GENERATE-KEY
payu.test_url=https://test.payu.in/_payment

razorpay.key_id=MERCHANT_KEY
razorpay.secret_key=AUTO_GENERATE-KEY

spring.mail.host=smtp.gmail.com
spring.mail.port=PORT_NUMBER
spring.mail.username=EMAIL_ID
spring.mail.password=APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.ssl.trust=smtp.gmail.com
